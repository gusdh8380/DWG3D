# ──────────────────────────────────────────────
# DWG3D — 환경 변수 예시 (.env.example)
# 복사 후 .env 로 저장하여 사용: cp .env.example .env
# ──────────────────────────────────────────────

# ─── Database ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dwg3d:secret@db:5432/dwg3d
DATABASE_SYNC_URL=postgresql+psycopg2://dwg3d:secret@db:5432/dwg3d

# ─── Redis / Celery ──────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Storage (MinIO for local dev) ───────────
S3_ENDPOINT=http://minio:9000              # 내부 Docker 주소 (워커 → MinIO)
S3_PRESIGN_ENDPOINT=http://localhost:9000  # 외부 주소 (클라이언트 presign URL)
S3_BUCKET=dwg3d
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
# CDN URL (프로덕션: CloudFront URL, 로컬: MinIO public URL)
S3_PUBLIC_URL=http://localhost:9000/dwg3d

# ─── APS (Autodesk Platform Services) ────────
# 비워두면 mock 변환 모드로 동작
APS_CLIENT_ID=
APS_CLIENT_SECRET=
USE_MOCK_CONVERSION=true

# ─── n8n 오케스트레이션 ────────────────────
# 비워두면 n8n 연동 없이 Celery 직접 실행
N8N_WEBHOOK_URL=http://n8n:5678/webhook/upload-complete

# ─── App 설정 ─────────────────────────────────
DEBUG=true
MAX_UPLOAD_SIZE_MB=500
TEMP_DIR=/tmp/dwg3d
